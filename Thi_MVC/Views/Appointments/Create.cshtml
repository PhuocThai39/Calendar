@model CalendarAppointmentApp.ViewModels.AddAppointmentViewModel

@{
    ViewData["Title"] = "Thêm lịch hẹn";
}

<div class="page-center">
    <div class="modern-form-card">

        <!-- TITLE -->
        <div class="form-title">
            <h1>Thêm lịch hẹn</h1>
            <p>Nhập thông tin lịch hẹn mới của bạn.</p>
        </div>

        <!-- ALERT -->
        @if (TempData["Warning"] != null)
        {
            <div class="alert warning">@TempData["Warning"]</div>
        }

        @if (TempData["Question"] != null)
        {
            <div class="alert info">@TempData["Question"]</div>
        }

        <!-- FORM -->
        <form asp-action="Create" method="post">

            <!-- 🔥 HIỆN TOÀN BỘ LỖI -->
            <div asp-validation-summary="All" class="validation-box"></div>

            <input type="hidden" asp-for="ConflictAppointmentId" />
            <input type="hidden" asp-for="MatchingGroupMeetingId" />
            <input type="hidden" asp-for="ConflictGroupMeetingName" />

            <!-- ĐÃ THÊM: Khu vực chọn loại lịch hẹn (Radio Buttons) -->
            <div class="form-group" style="margin-bottom: 20px; background: #f8f9fa; padding: 15px; border-radius: 8px; border: 1px solid #e9ecef;">
                <label style="display: block; margin-bottom: 10px; font-weight: 600; color: #495057;">Phân loại lịch hẹn:</label>
                <div style="display: flex; gap: 20px;">
                    <label style="cursor: pointer; display: flex; align-items: center; gap: 5px;">
                        <input type="radio" asp-for="IsStartNewGroupMeeting" value="false" checked />
                        <span>👤 Lịch cá nhân</span>
                    </label>
                    <label style="cursor: pointer; display: flex; align-items: center; gap: 5px;">
                        <input type="radio" asp-for="IsStartNewGroupMeeting" value="true" />
                        <span>👥 Bắt đầu cuộc họp nhóm</span>
                    </label>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Name">Tên lịch hẹn</label>
                <input asp-for="Name" class="form-control" placeholder="VD: Sprint Planning" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Location">Địa điểm</label>
                <input asp-for="Location" class="form-control" placeholder="VD: Phòng họp A" />
                <span asp-validation-for="Location" class="text-danger"></span>
            </div>

            <div class="form-row">

                <div class="form-group">

                    <label asp-for="StartTime">Thời gian bắt đầu</label>
                    <input asp-for="StartTime" class="form-control" />

                    <span asp-validation-for="StartTime" class="text-danger"></span>
                </div>

                <div class="form-group">

                    <label asp-for="EndTime">Thời gian kết thúc</label>
                    <input asp-for="EndTime" class="form-control" />

                    <span asp-validation-for="EndTime" class="text-danger"></span>
                </div>

            </div>

            <div class="checkbox-card">
                <input asp-for="HasReminder" />
                <label asp-for="HasReminder">Thêm lời nhắc cho lịch hẹn</label>
            </div>

            <div class="form-row">

                <div class="form-group">

                    <label asp-for="ReminderMinutesBefore">Nhắc trước</label>
                    <select asp-for="ReminderMinutesBefore" class="form-control">
                        <option value="">-- Chọn thời gian --</option>
                        <option value="5">5 phút</option>
                        <option value="15">15 phút</option>
                        <option value="30">30 phút</option>
                        <option value="60">1 giờ</option>
                        <option value="1440">1 ngày</option>
                    </select>
                    <span asp-validation-for="ReminderMinutesBefore" class="text-danger"></span>

                </div>

                <div class="form-group">
                    <label asp-for="ReminderMessage">Nội dung nhắc</label>
                    <input asp-for="ReminderMessage" class="form-control" placeholder="VD: Chuẩn bị tài liệu" />
                </div>

            </div>

            @if (Model.ConflictAppointmentId != null)
            {
                <div class="checkbox-card warning-box">
                    <input asp-for="ReplaceOldAppointment" />
                    <label asp-for="ReplaceOldAppointment">
                        Thay thế lịch hẹn cũ
                    </label>
                </div>
            }

            <!-- GROUP MEETING -->
            @if (Model.MatchingGroupMeetingId != null)
            {
                <div class="meeting-confirm-box">

                    <div class="meeting-icon">👥</div>

                    <div class="meeting-content">
                        <h3>Phát hiện cuộc họp nhóm</h3>

                        <!-- ĐÃ SỬA: Hiển thị tên nhóm bị trùng -->
                        <p>
                            Đang có nhóm <strong>'@Model.ConflictGroupMeetingName'</strong> họp tại địa điểm này trong cùng khung giờ.
                            Bạn có muốn tham gia chung không?
                        </p>

                        <div class="meeting-actions" style="margin-top: 15px;">
                            <button type="submit" name="JoinGroupMeeting" value="true" class="btn-join" style="padding: 10px 20px; background: #0d6efd; color: white; border: none; border-radius: 6px; cursor: pointer; margin-right: 10px;">
                                Đồng ý tham gia
                            </button>

                            <button type="submit" name="JoinGroupMeeting" value="false" class="btn-skip" style="padding: 10px 20px; background: #6c757d; color: white; border: none; border-radius: 6px; cursor: pointer;">
                                Không, tiếp tục tạo

                            </button>

                        </div>
                    </div>
                </div>
            }
            else
            {
                <!-- ĐÃ SỬA: Chỉ hiện nút "Lưu lịch hẹn" gốc khi KHÔNG CÓ bảng hỏi nhóm -->
                <div class="form-actions mt-4">
                    <button type="submit" class="btn-dark">Lưu lịch hẹn</button>
                    <a asp-action="Index" class="btn-light">Quay lại</a>
                </div>
            }
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}