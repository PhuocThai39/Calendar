@model IEnumerable<CalendarAppointmentApp.Models.Appointment>

@{
    ViewData["Title"] = "Thông báo của bạn";
}

<!-- ĐÃ SỬA: Thêm display: block và width: 100% để ép các khối phải rớt dòng, không bị dính ngang nhau -->
<div class="page-center" style="max-width: 800px; margin: 40px auto; width: 100%; display: block;">
    
    <!-- Phần Tiêu đề -->
    <div style="margin-bottom: 30px; border-bottom: 2px solid #eee; padding-bottom: 15px;">
        <h1 style="margin: 0; font-size: 28px; display: flex; align-items: center; gap: 10px;">
            <span style="font-size: 32px;">🔔</span> Thông báo nhắc nhở
        </h1>
    </div>

    <!-- Phần Danh sách thông báo -->
    <div style="display: flex; flex-direction: column; gap: 20px;">
        @if (!Model.Any())
        {
            <div style="text-align: center; padding: 50px; background: #f8f9fa; border-radius: 12px; color: #6c757d;">
                <h3>Không có thông báo nào mới!</h3>
                <p>Bạn đã hoàn thành hoặc chưa có lịch hẹn nào sắp diễn ra.</p>
            </div>
        }
        else
        {
            foreach (var item in Model)
            {
                var reminder = item.Reminders.FirstOrDefault();
                
                <div style="background: #fff; border-left: 5px solid #ffc107; border-radius: 8px; padding: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px;">
                    
                    <div style="flex: 1;">
                        <div style="color: #856404; font-size: 13px; font-weight: 700; margin-bottom: 10px; background: #fff3cd; display: inline-block; padding: 4px 12px; border-radius: 20px;">
                            Sắp diễn ra lúc @item.StartTime.ToString("HH:mm dd/MM/yyyy")
                        </div>
                        
                        <h3 style="margin: 0 0 10px 0; color: #212529;">@item.Name</h3>
                        
                        <div style="color: #495057; font-size: 15px; margin-bottom: 8px;">
                            <strong>Nội dung:</strong> @(reminder?.Message ?? "Không có lời nhắn")
                        </div>
                        
                        <div style="color: #6c757d; font-size: 14px; display: flex; flex-wrap: wrap; gap: 15px;">
                            <span style="display: flex; align-items: center; gap: 4px;">📍 @item.Location</span>
                            <span style="display: flex; align-items: center; gap: 4px;">⏱️ Nhắc trước @(reminder?.MinutesBefore ?? 0) phút</span>
                        </div>
                    </div>

                    <div>
                        <a asp-action="Details" asp-route-id="@item.Id" style="background: #212529; color: #fff; padding: 10px 20px; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 14px; display: inline-block; white-space: nowrap; transition: 0.2s;">
                            Xem chi tiết
                        </a>
                    </div>
                </div>
            }
        }
    </div>
</div>