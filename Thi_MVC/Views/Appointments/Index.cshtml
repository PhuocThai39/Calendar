@model CalendarAppointmentApp.ViewModels.CalendarMonthViewModel

@{
    ViewData["Title"] = "Lịch hẹn";
    string[] dayNames = { "SUN", "MON", "TUE", "WED", "THU", "FRI", "SAT" };
}

<div class="calendar-shell">

    <div class="calendar-header">
        <div>
            <h1>@Model.Title.ToUpper()</h1>
            <p>Quản lý lịch hẹn theo tháng</p>
        </div>

        <div class="calendar-actions" style="display: flex; align-items: center; gap: 12px;">
            
            <a asp-action="Index" class="btn-today">Hôm nay</a>

            <a class="nav-icon-btn"
                   asp-action="Index"
                   asp-route-month="@Model.PreviousMonth.Month"
                   asp-route-year="@Model.PreviousMonth.Year"
                   title="Tháng trước">
                &#10094;
            </a>

            <form asp-action="Index" method="get" class="month-form" style="display: flex; gap: 8px; margin: 0;">
                <select name="month" onchange="this.form.submit()" class="custom-select">
                    @for (int m = 1; m <= 12; m++)
                    {
                        if (m == Model.Month)
                        {
                            <option value="@m" selected>Tháng @m</option>
                        }
                        else
                        {
                            <option value="@m">Tháng @m</option>
                        }
                    }
                </select>

                <select name="year" onchange="this.form.submit()" class="custom-select">
                    @for (int y = DateTime.Today.Year - 5; y <= DateTime.Today.Year + 5; y++)
                    {
                        if (y == Model.Year)
                        {
                            <option value="@y" selected>@y</option>
                        }
                        else
                        {
                            <option value="@y">@y</option>
                        }
                    }
                </select>
            </form>

            <a class="nav-icon-btn"
                   asp-action="Index"
                   asp-route-month="@Model.NextMonth.Month"
                   asp-route-year="@Model.NextMonth.Year"
                   title="Tháng sau">
                &#10095;
            </a>

            <a asp-action="Create" class="add-btn" style="margin-left: 10px;">
                + Thêm lịch hẹn
            </a>

        </div>
    </div>

    <div class="calendar-weekdays">
        @foreach (var day in dayNames)
        {
            <div>@day</div>
        }
    </div>

    <div class="calendar-grid-month">
        @foreach (var day in Model.Days)
        {
            <div class="calendar-day @(day.IsCurrentMonth ? "" : "muted-day") @(day.IsToday ? "today-highlight" : "")">

                <div class="day-number">@day.Date.Day.ToString("00")</div>

                <div class="day-events">

                    @foreach (var appointment in day.Appointments.Take(3))
                    {
                        @* ĐÃ THÊM: asp-route-isGroup để truyền sang hàm Details *@
                        <a asp-action="Details"
                               asp-route-id="@appointment.Id"
                               asp-route-isGroup="@appointment.IsGroupMeeting"
                               class="event-pill @GetEventClass(appointment.Id)">

                            <span>@appointment.StartTime.ToString("HH:mm")</span>
                            
                            @* ĐÃ THÊM: Icon nhận diện họp nhóm *@
                            @if (appointment.IsGroupMeeting)
                            {
                                <span title="Họp nhóm" style="margin-right: 3px;">👥</span>
                            }
                            @appointment.Name
                        </a>
                    }

                    @if (day.Appointments.Count > 3)
                    {
                        <div class="more-events">
                            +@(day.Appointments.Count - 3) lịch hẹn khác
                        </div>
                    }

                </div>

            </div>
        }
    </div>
</div>

@functions {
    string GetEventClass(int id)
    {
        string[] classes =
        {
            "event-purple",
            "event-pink",
            "event-blue",
            "event-orange",
            "event-green",
            "event-red"
        };

        return classes[id % classes.Length];
    }
}