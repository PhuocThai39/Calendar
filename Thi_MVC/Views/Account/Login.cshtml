@model CalendarAppointmentApp.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div style="max-width: 400px; margin: 80px auto; background: #fff; padding: 40px; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.08);">
    <div style="text-align: center; margin-bottom: 30px;">
        <h2 style="margin: 0; color: #212529;">Đăng nhập</h2>
        <p style="color: #6c757d;">Chào mừng bạn quay lại Calendar App</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div style="background: #d4edda; color: #155724; padding: 10px; border-radius: 6px; margin-bottom: 20px; text-align: center;">@TempData["Success"]</div>
    }

    <form asp-action="Login" method="post">
        <div asp-validation-summary="ModelOnly" style="color: #dc3545; margin-bottom: 15px;"></div>

        <div style="margin-bottom: 15px;">
            <label style="display: block; margin-bottom: 5px; font-weight: 500; font-size: 14px;">Tài khoản</label>
            <input asp-for="Username" style="width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 6px;" placeholder="Nhập username..." />
            <span asp-validation-for="Username" style="color: #dc3545; font-size: 13px;"></span>
        </div>

        <div style="margin-bottom: 25px;">
            <label style="display: block; margin-bottom: 5px; font-weight: 500; font-size: 14px;">Mật khẩu</label>
            <input asp-for="Password" style="width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 6px;" placeholder="Nhập mật khẩu..." />
            <span asp-validation-for="Password" style="color: #dc3545; font-size: 13px;"></span>
        </div>

        <button type="submit" style="width: 100%; background: #212529; color: #fff; border: none; padding: 12px; border-radius: 6px; font-weight: 600; cursor: pointer; transition: 0.2s;">Đăng nhập</button>
    </form>

    <div style="text-align: center; margin-top: 20px; font-size: 14px;">
        Chưa có tài khoản? <a asp-action="Register" style="color: #0d6efd; text-decoration: none; font-weight: 600;">Đăng ký ngay</a>
    </div>
</div>